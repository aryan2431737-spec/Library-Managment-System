PORT=3000
ADMIN_SECRET_ID=7905

# Database (required for persistent users/sessions)
# Use your hosted MySQL hostname on Render, not localhost.
DB_HOST=your-managed-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password
DB_NAME=library_db
DB_CONNECT_TIMEOUT_MS=4000
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Session storage
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_MAX_AGE_DAYS=7

# Dev only: set to true to allow in-memory mock data instead of DB (not persistent)
ALLOW_MOCK_DATA=false

# CORS (only if serving frontend from another origin)
# CLIENT_ORIGIN=https://your-frontend-domain
